{
  "name": "chauffeur-ms",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:local": "dotenvx run --env-file=.env.dev -- nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:push:dev": "dotenvx run --env-file=.env.dev -- drizzle-kit push --config=drizzle-dev.config.ts",
    "db:studio:dev": "dotenvx run --env-file=.env.dev -- drizzle-kit studio --config=drizzle-dev.config.ts"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@nuxt/ui": "4.5.1",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.3.1",
    "postgres": "^3.4.8",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/hints": "1.0.0-alpha.10",
    "@types/google.maps": "^3.58.1",
    "drizzle-kit": "^0.31.9"
  }
}
